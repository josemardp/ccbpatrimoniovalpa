generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PapelUsuario {
  gestor_adm
}

enum StatusRotina {
  vazio
  ok
  pendente
  nao
  na
}

enum EtapaForm148 {
  elaborado
  ass_min
  ins_siga
  pendencias
  escaneado
}

enum TipoMovimento {
  entrada
  saida
  transferencia
  baixa
}

enum EstadoConservacao {
  otimo
  bom
  regular
  ruim
  descartado
}

model Administracao {
  id                    String           @id @default(cuid())
  nome                  String
  cidade                String
  uf                    String           @default("SP")
  cnpj                  String           @unique
  responsavelPatrimonio String
  regional              String
  ativa                 Boolean          @default(true)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  casas                 CasaOracao[]
  usuarios              Usuario[]
  auditLogs             AuditLog[]
  controlesMensais      ControleMensal[]
  form148Statuses       Form148Status[]
  documentos            Documento[]
  movimentos            Movimento[]
  bensPatrimoniais      BemPatrimonial[]

  @@map("administracoes")
}

model CasaOracao {
  id                    String           @id @default(cuid())
  administracaoId       String
  codigoSiga            String           @unique
  nome                  String
  cidade                String
  uf                    String           @default("SP")
  anciaoCooperador      String?
  responsavelPatrimonio String?
  ativa                 Boolean          @default(true)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  administracao         Administracao    @relation(fields: [administracaoId], references: [id], onDelete: Cascade)
  usuarios              Usuario[]
  form148Statuses       Form148Status[]
  documentos            Documento[]
  movimentosOrigem      Movimento[]      @relation("MovimentoOrigem")
  movimentosDestino     Movimento[]      @relation("MovimentoDestino")
  bensPatrimoniais      BemPatrimonial[]

  @@index([administracaoId])
  @@map("casas_oracao")
}

model Usuario {
  id                          String           @id @default(cuid())
  authUserId                  String?          @unique
  administracaoId             String
  casaOracaoId                String?
  nome                        String
  email                       String           @unique
  papel                       PapelUsuario     @default(gestor_adm)
  ativo                       Boolean          @default(true)
  lastLoginAt                 DateTime?
  createdAt                   DateTime         @default(now())
  updatedAt                   DateTime         @updatedAt
  administracao               Administracao    @relation(fields: [administracaoId], references: [id], onDelete: Cascade)
  casaOracao                  CasaOracao?      @relation(fields: [casaOracaoId], references: [id], onDelete: SetNull)
  auditLogs                   AuditLog[]
  controlesMensaisAtualizados ControleMensal[] @relation("ControleMensalAtualizadoPor")
  form148StatusesAtualizados  Form148Status[]  @relation("Form148StatusAtualizadoPor")
  documentosUploadados        Documento[]
  movimentosRegistrados       Movimento[]
  bensRegistrados             BemPatrimonial[]

  @@index([administracaoId])
  @@index([casaOracaoId])
  @@map("usuarios")
}

model AuditLog {
  id              String         @id @default(cuid())
  usuarioId       String?
  administracaoId String?
  action          String
  entity          String
  entityId        String?
  ip              String?
  metadata        Json?
  createdAt       DateTime       @default(now())
  usuario         Usuario?       @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  administracao   Administracao? @relation(fields: [administracaoId], references: [id], onDelete: SetNull)

  @@index([usuarioId])
  @@index([administracaoId])
  @@index([entity, entityId])
  @@map("audit_log")
}

model Form148Status {
  id              String        @id @default(cuid())
  administracaoId String
  casaOracaoId    String
  competenciaAno  Int
  competenciaMes  Int
  etapa           EtapaForm148
  status          StatusRotina  @default(vazio)
  atualizadoPorId String?
  atualizadoEm    DateTime      @updatedAt
  createdAt       DateTime      @default(now())
  administracao   Administracao @relation(fields: [administracaoId], references: [id], onDelete: Cascade)
  casaOracao      CasaOracao    @relation(fields: [casaOracaoId], references: [id], onDelete: Cascade)
  atualizadoPor   Usuario?      @relation("Form148StatusAtualizadoPor", fields: [atualizadoPorId], references: [id], onDelete: SetNull)

  @@unique([casaOracaoId, competenciaAno, competenciaMes, etapa])
  @@index([administracaoId, competenciaAno, competenciaMes])
  @@map("form_148_status")
}

model ControleMensal {
  id              String        @id @default(cuid())
  administracaoId String
  tarefaId        String
  competenciaAno  Int
  competenciaMes  Int
  status          StatusRotina  @default(vazio)
  atualizadoPorId String?
  atualizadoEm    DateTime      @updatedAt
  createdAt       DateTime      @default(now())
  administracao   Administracao @relation(fields: [administracaoId], references: [id], onDelete: Cascade)
  atualizadoPor   Usuario?      @relation("ControleMensalAtualizadoPor", fields: [atualizadoPorId], references: [id], onDelete: SetNull)

  @@unique([administracaoId, tarefaId, competenciaAno, competenciaMes])
  @@index([administracaoId, competenciaAno, competenciaMes])
  @@map("controle_mensal")
}

model Documento {
  id              String        @id @default(cuid())
  administracaoId String
  casaOracaoId    String
  competenciaAno  Int
  competenciaMes  Int
  tipo            String
  storagePath     String
  nomeOriginal    String
  tamanhoBytes    Int
  uploadadoPorId  String?
  createdAt       DateTime      @default(now())
  administracao   Administracao @relation(fields: [administracaoId], references: [id], onDelete: Cascade)
  casaOracao      CasaOracao    @relation(fields: [casaOracaoId], references: [id], onDelete: Cascade)
  uploadadoPor    Usuario?      @relation(fields: [uploadadoPorId], references: [id], onDelete: SetNull)

  @@index([casaOracaoId, competenciaAno, competenciaMes])
  @@map("documentos")
}

model Movimento {
  id              String        @id @default(cuid())
  administracaoId String
  casaOrigemId    String?
  casaDestinoId   String?
  tipo            TipoMovimento
  descricao       String
  dataMovimento   DateTime
  documento       String?
  registradoPorId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  administracao   Administracao @relation(fields: [administracaoId], references: [id], onDelete: Cascade)
  casaOrigem      CasaOracao?   @relation("MovimentoOrigem", fields: [casaOrigemId], references: [id], onDelete: SetNull)
  casaDestino     CasaOracao?   @relation("MovimentoDestino", fields: [casaDestinoId], references: [id], onDelete: SetNull)
  registradoPor   Usuario?      @relation(fields: [registradoPorId], references: [id], onDelete: SetNull)

  @@index([administracaoId, dataMovimento])
  @@map("movimentos")
}

model BemPatrimonial {
  id                String            @id @default(cuid())
  administracaoId   String
  casaOracaoId      String
  codigoInterno     String
  descricao         String
  categoria         String
  marca             String?
  modelo            String?
  numeroSerie       String?
  dataAquisicao     DateTime?
  valorAquisicao    Decimal?          @db.Decimal(12, 2)
  estadoConservacao EstadoConservacao @default(bom)
  observacoes       String?
  ativo             Boolean           @default(true)
  registradoPorId   String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  administracao     Administracao     @relation(fields: [administracaoId], references: [id], onDelete: Cascade)
  casaOracao        CasaOracao        @relation(fields: [casaOracaoId], references: [id], onDelete: Cascade)
  registradoPor     Usuario?          @relation(fields: [registradoPorId], references: [id], onDelete: SetNull)

  @@unique([administracaoId, codigoInterno])
  @@index([casaOracaoId])
  @@index([administracaoId, categoria])
  @@map("bens_patrimoniais")
}
